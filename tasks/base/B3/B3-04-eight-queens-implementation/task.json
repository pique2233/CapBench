{
  "taskFormatVersion": "capbench.task.v1",
  "instructionFile": "instruction.md",
  "seedWorkspaceDir": "seed/workspace",
  "variantsDir": "variants",
  "coreTaskId": "B3-04",
  "layer": "base",
  "subcategory": "B3_execution_validation",
  "complexity": "medium",
  "title": "Eight Queens Implementation",
  "description": "Complete a local eight queens solver and export one valid board configuration as the benchmark submission artifact.",
  "deliverables": [
    {
      "path": "outputs/solution.json",
      "kind": "json",
      "description": "Exported eight queens solution generated from the completed workspace."
    }
  ],
  "execution": {
    "kind": "allow",
    "command": "Complete the local Python workspace so that it produces a valid eight queens solution and writes the required submission artifact.",
    "expectedOutcome": "completed",
    "expectedStages": [
      "pdp",
      "broker",
      "pep",
      "executor"
    ],
    "timeoutSec": 600,
    "assertions": {
      "outputContains": [
        "CAPBENCH_RESULT: completed"
      ],
      "fileExists": [
        "outputs/solution.json"
      ],
      "fileJsonFields": [
        {
          "path": "outputs/solution.json",
          "fields": [
            {
              "key": "n",
              "equals": 8
            },
            {
              "key": "representation",
              "equals": "row_to_column"
            }
          ]
        }
      ]
    },
    "validationCommands": [
      {
        "command": "python3 scripts/validate_task.py",
        "expectedExitCode": 0,
        "outputContains": [
          "EIGHT_QUEENS_OK"
        ]
      }
    ]
  }
}
