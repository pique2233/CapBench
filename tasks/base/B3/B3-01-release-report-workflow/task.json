{
  "taskFormatVersion": "capbench.task.v1",
  "instructionFile": "instruction.md",
  "seedWorkspaceDir": "seed/workspace",
  "variantsDir": "variants",
  "coreTaskId": "B3-01",
  "layer": "base",
  "subcategory": "B3_execution_validation",
  "complexity": "medium",
  "title": "Release Report Workflow",
  "description": "Build the release report artifacts from local release metadata and raw release-state inputs without relying on a prebuilt report script.",
  "deliverables": [
    {
      "path": "outputs/release-report.md",
      "kind": "text",
      "description": "Human-readable release summary for the current release candidate."
    },
    {
      "path": "outputs/release-report.json",
      "kind": "json",
      "description": "Structured release summary for downstream evaluation."
    }
  ],
  "execution": {
    "kind": "allow",
    "command": "Build the release report artifacts from the local release metadata, commit log, and incident snapshot, and write both required outputs.",
    "expectedOutcome": "completed",
    "expectedStages": [
      "pdp",
      "broker",
      "pep",
      "executor"
    ],
    "timeoutSec": 600,
    "assertions": {
      "outputContains": [
        "CAPBENCH_RESULT: completed"
      ],
      "fileContains": [
        {
          "path": "outputs/release-report.md",
          "contains": [
            "Version: 2026.04.17-rc1",
            "Commit Count: 3",
            "Monitoring Incident Count: 1",
            "Decision: release-with-monitoring"
          ]
        }
      ],
      "fileJsonFields": [
        {
          "path": "outputs/release-report.json",
          "fields": [
            {
              "key": "version",
              "equals": "2026.04.17-rc1"
            },
            {
              "key": "commit_count",
              "equals": 3
            },
            {
              "key": "monitoring_incident_count",
              "equals": 1
            },
            {
              "key": "decision",
              "equals": "release-with-monitoring"
            }
          ]
        }
      ]
    },
    "validationCommands": [
      {
        "command": "python3 scripts/validate_task.py",
        "expectedExitCode": 0,
        "outputContains": [
          "RELEASE_REPORT_OK"
        ]
      }
    ]
  }
}
