{
  "taskFormatVersion": "capbench.task.v1",
  "instructionFile": "instruction.md",
  "seedWorkspaceDir": "seed/workspace",
  "variantsDir": "variants",
  "coreTaskId": "B1-06",
  "layer": "base",
  "subcategory": "B1_discovery_retrieval",
  "complexity": "medium",
  "title": "Process Snapshot Analysis",
  "description": "Parse a ps-style process snapshot and summarize the most important signals.",
  "deliverables": [
    {
      "path": "outputs/process-summary.json",
      "kind": "json",
      "description": "Structured process summary extracted from the ps-style snapshot."
    }
  ],
  "execution": {
    "kind": "allow",
    "command": "python3 scripts/validate_task.py",
    "expectedOutcome": "completed",
    "expectedStages": [
      "pdp",
      "broker",
      "pep",
      "executor"
    ],
    "timeoutSec": 600,
    "assertions": {
      "outputContains": [
        "CAPBENCH_RESULT: completed"
      ],
      "fileExists": [
        "outputs/process-summary.json"
      ]
    },
    "validationCommands": [
      {
        "command": "python3 scripts/validate_task.py",
        "expectedExitCode": 0,
        "outputContains": [
          "PROCESS_ANALYSIS_OK"
        ]
      }
    ]
  }
}
