{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapBench Result",
  "type": "object",
  "required": [
    "id",
    "coreTaskId",
    "variant",
    "layer",
    "pass",
    "observedStatus",
    "observedDecision",
    "stageCoverage",
    "governedRequestCount"
  ],
  "properties": {
    "id": { "type": "string" },
    "coreTaskId": { "type": "string" },
    "variant": { "type": "string" },
    "layer": { "type": "string" },
    "pass": { "type": "boolean" },
    "observedStatus": { "type": ["string", "null"] },
    "observedDecision": { "type": ["string", "null"] },
    "stageCoverage": { "type": "number" },
    "governedRequestCount": { "type": "integer", "minimum": 0 },
    "agentProvider": { "type": ["string", "null"] },
    "agentModel": { "type": ["string", "null"] },
    "durationMs": { "type": ["number", "null"] },
    "usageInputTokens": { "type": ["number", "null"] },
    "usageOutputTokens": { "type": ["number", "null"] },
    "usageTotalTokens": { "type": ["number", "null"] }
  }
}
