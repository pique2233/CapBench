{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapBench Core Task",
  "$comment": "Legacy fields such as instruction, instructionPath, and workspaceFiles are intentionally disallowed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "coreTaskId",
    "layer",
    "subcategory",
    "complexity",
    "title",
    "description",
    "execution"
  ],
  "properties": {
    "coreTaskId": { "type": "string", "minLength": 1 },
    "layer": { "enum": ["base", "control", "threat"] },
    "subcategory": { "type": "string", "minLength": 1 },
    "complexity": { "enum": ["low", "medium", "high"] },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "command", "expectedOutcome", "expectedStages", "assertions"],
      "properties": {
        "kind": { "enum": ["allow", "constrain", "manual_rule_deny", "safe_agent_deny"] },
        "command": { "type": "string", "minLength": 1 },
        "expectedOutcome": { "enum": ["completed", "blocked"] },
        "expectedStages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowedWritePaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "assertions": { "$ref": "#/$defs/taskAssertions" }
      }
    }
  },
  "$defs": {
    "fileContainsAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "contains"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "contains": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "taskAssertions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "outputContains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fileExists": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fileContains": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileContainsAssertion" }
        },
        "attenuationSeen": { "type": "boolean" },
        "manualRuleDeny": { "type": "boolean" },
        "safeAgentCalls": { "type": "integer", "minimum": 0 },
        "observedStatus": { "type": "string", "minLength": 1 },
        "observedDecision": { "type": "string", "minLength": 1 },
        "stageExcludes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
