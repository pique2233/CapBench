{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapBench Core Task",
  "$comment": "Legacy fields such as instruction, instructionPath, and workspaceFiles are intentionally disallowed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskFormatVersion",
    "instructionFile",
    "seedWorkspaceDir",
    "variantsDir",
    "coreTaskId",
    "layer",
    "subcategory",
    "complexity",
    "title",
    "description",
    "deliverables",
    "execution"
  ],
  "properties": {
    "taskFormatVersion": { "const": "capbench.task.v1" },
    "instructionFile": { "const": "instruction.md" },
    "seedWorkspaceDir": { "const": "seed/workspace" },
    "variantsDir": { "const": "variants" },
    "coreTaskId": { "type": "string", "minLength": 1 },
    "layer": { "enum": ["base", "control", "threat"] },
    "subcategory": { "type": "string", "minLength": 1 },
    "complexity": { "enum": ["low", "medium", "high"] },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "deliverables": {
      "type": "array",
      "items": { "$ref": "#/$defs/deliverableDefinition" }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "command", "expectedOutcome", "expectedStages", "timeoutSec", "assertions"],
      "properties": {
        "kind": { "enum": ["allow", "constrain", "manual_rule_deny", "safe_agent_deny"] },
        "command": { "type": "string", "minLength": 1 },
        "expectedOutcome": { "enum": ["completed", "blocked"] },
        "expectedStages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "timeoutSec": {
          "type": "integer",
          "minimum": 30,
          "maximum": 900
        },
        "allowedWritePaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "validationCommands": {
          "type": "array",
          "items": { "$ref": "#/$defs/validationCommand" }
        },
        "assertions": { "$ref": "#/$defs/taskAssertions" }
      }
    }
  },
  "$defs": {
    "fileContainsAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "contains"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "contains": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "jsonFieldExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "equals"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "equals": {
          "type": ["string", "number", "boolean", "null"]
        }
      }
    },
    "fileJsonFieldsAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "fields"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/jsonFieldExpectation" }
        }
      }
    },
    "deliverableDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "description"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["text", "json"] },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "validationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "expectedExitCode"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "expectedExitCode": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "outputContains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "outputExcludes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "taskAssertions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "outputContains": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "outputExcludes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fileExists": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fileContains": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileContainsAssertion" }
        },
        "fileJsonFields": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileJsonFieldsAssertion" }
        },
        "attenuationSeen": { "type": "boolean" },
        "manualRuleDeny": { "type": "boolean" },
        "observedStatus": { "type": "string", "minLength": 1 },
        "observedDecision": { "type": "string", "minLength": 1 },
        "filesUnchanged": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "stageExcludes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
