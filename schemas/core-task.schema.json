{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapBench Core Task",
  "type": "object",
  "required": [
    "coreTaskId",
    "layer",
    "subcategory",
    "complexity",
    "title",
    "description",
    "instruction",
    "execution"
  ],
  "properties": {
    "coreTaskId": { "type": "string" },
    "layer": { "enum": ["base", "control", "threat"] },
    "subcategory": { "type": "string" },
    "complexity": { "enum": ["low", "medium", "high"] },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "instruction": { "type": "string" },
    "execution": {
      "type": "object",
      "required": ["kind", "command", "expectedOutcome", "expectedStages", "assertions"],
      "properties": {
        "kind": { "enum": ["allow", "constrain", "manual_rule_deny", "safe_agent_deny"] },
        "command": { "type": "string" },
        "expectedOutcome": { "enum": ["completed", "blocked"] },
        "expectedStages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
