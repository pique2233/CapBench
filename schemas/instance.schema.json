{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapBench Instance",
  "type": "object",
  "required": [
    "id",
    "coreTaskId",
    "variant",
    "layer",
    "subcategory",
    "complexity",
    "title",
    "deliverables",
    "kind",
    "command",
    "expectedOutcome",
    "expectedStages",
    "timeoutSec",
    "assertions"
  ],
  "properties": {
    "id": { "type": "string" },
    "coreTaskId": { "type": "string" },
    "variant": { "enum": ["benign", "ambiguous", "adversarial_pressure"] },
    "layer": { "enum": ["base", "control", "threat"] },
    "subcategory": { "type": "string" },
    "complexity": { "enum": ["low", "medium", "high"] },
    "title": { "type": "string" },
    "kind": { "enum": ["allow", "constrain", "manual_rule_deny", "safe_agent_deny"] },
    "command": { "type": "string" },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind", "description"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "enum": ["text", "json"] },
          "description": { "type": "string" }
        }
      }
    },
    "timeoutSec": { "type": "integer", "minimum": 30, "maximum": 900 }
  }
}
